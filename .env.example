# ── MiniFrontier — Variables d'environnement (exemple) ────────────────────────
# Copier en .env et ajuster. Le .env n'est JAMAIS committé (voir .gitignore).

# ── Serveur LLM local pour la génération de données synthétiques ───────────────
OLLAMA_HOST=192.168.1.190
OLLAMA_PORT=8085
OLLAMA_MODEL=qwen3:27b

# Backend vLLM alternatif (OpenAI-compatible)
# VLLM_HOST=192.168.1.190
# VLLM_PORT=8085
# VLLM_MODEL=Qwen/Qwen2.5-7B-Instruct

# ── Sélection GPU (multi-GPU local) ───────────────────────────────────────────
# Forcer un GPU précis : 0 = RTX 3090, 1 = RTX 5060 Ti
# CUDA_VISIBLE_DEVICES=0

# ── Monitoring optionnel ──────────────────────────────────────────────────────
# WANDB_API_KEY=
# WANDB_PROJECT=mini-frontier

# ── Overrides d'entraînement (optionnel) ──────────────────────────────────────
# Ces valeurs ont des défauts sains dans config.py ; ne surcharger qu'au besoin.
# MAX_ITERS=10000
# LEARNING_RATE=1.5e-4
